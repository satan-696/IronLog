{
  "name": "@ironlog/server",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev":          "nodemon src/index.js",
    "start":        "node src/index.js",
    "db:generate":  "prisma generate",
    "db:migrate":   "prisma migrate deploy",
    "db:dev":       "prisma migrate dev",
    "build":        "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "express":         "^4.18.2",
    "@prisma/client":  "^5.14.0",
    "bcryptjs":        "^2.4.3",
    "jsonwebtoken":    "^9.0.2",
    "cors":            "^2.8.5",
    "dotenv":          "^16.4.5"
  },
  "devDependencies": {
    "prisma":  "^5.14.0",
    "nodemon": "^3.1.4"
  }
}
