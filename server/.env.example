SERVER_ENV=# IronLog Server — Environment Variables
# Copy to .env and fill in the values

# PostgreSQL connection string (Render provides this automatically)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ironlog?sslmode=require"

# JWT signing secret — generate a strong random string (≥32 chars)
JWT_SECRET="change-me-to-a-long-random-secret"

# Port the Express server listens on
PORT=5000

# CORS allowed origin — set to your frontend URL in production
CLIENT_URL="http://localhost:5173"
